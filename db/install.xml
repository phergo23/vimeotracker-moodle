<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="filter/vimeotracker/db" VERSION="20260605" COMMENT="Base de datos global para el filtro Vimeo Tracker">
  <TABLES>
    <TABLE NAME="filter_vimeotracker_time" COMMENT="Guarda el progreso de visualizacion de cualquier video de Vimeo en el sitio">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="vimeo_id" TYPE="char" LENGTH="50" NOTNULL="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="last_position" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="percentage_watched" TYPE="int" LENGTH="3" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="is_completed" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="user_vimeo_clean" TYPE="unique" FIELDS="userid, vimeo_id, courseid"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>

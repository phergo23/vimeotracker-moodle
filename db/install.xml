<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/vimeotracker/db" VERSION="20260605" COMMENT="Base de datos limpia y corregida para mod_vimeotracker">
  <TABLES>
    <TABLE NAME="vimeotracker" COMMENT="Instancias de la actividad Vimeo Tracker">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="course" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="intro" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="introformat" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="vimeo_id" TYPE="char" LENGTH="20" NOTNULL="true"/>
        <FIELD NAME="vimeo_url" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="resume_enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="track_time" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="min_watch_percent" TYPE="int" LENGTH="3" NOTNULL="true" DEFAULT="80"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="course_fk" TYPE="foreign" FIELDS="course" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
    </TABLE>

    <TABLE NAME="vimeotracker_watch_time" COMMENT="Progreso de los estudiantes">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="vimeotracker_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="last_position" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="total_time_watched" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="percentage_watched" TYPE="int" LENGTH="3" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="is_completed" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="in_progress"/>
        <FIELD NAME="video_duration" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="vimeotracker_fk" TYPE="foreign" FIELDS="vimeotracker_id" REFTABLE="vimeotracker" REFFIELDS="id"/>
        <KEY NAME="user_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="unique_user_video" TYPE="unique" FIELDS="vimeotracker_id, userid"/>
      </KEYS>
    </TABLE>

    <TABLE NAME="vimeotracker_events" COMMENT="Historial de logs de reproduccion">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="watch_time_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="event_type" TYPE="char" LENGTH="30" NOTNULL="true"/>
        <FIELD NAME="current_time" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
        <FIELD NAME="video_duration" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
        <FIELD NAME="session_duration" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="watch_time_fk" TYPE="foreign" FIELDS="watch_time_id" REFTABLE="vimeotracker_watch_time" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
